{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:ixo:domain-md:x-oracle-capsule:manifest:0.1.0",
  "title": "IXO Oracle Capsule release manifest",
  "description": "Host-neutral immutable release contract. This manifest requests capabilities but grants no live authority.",
  "type": "object",
  "required": [
    "apiVersion",
    "kind",
    "schema",
    "metadata",
    "provenance",
    "compatibility",
    "domains",
    "components",
    "tools",
    "requestedCapabilities",
    "effectCeiling",
    "external_checks_required"
  ],
  "properties": {
    "apiVersion": { "const": "ixo.earth/oracle-capsule/v0alpha1" },
    "kind": { "const": "OracleCapsuleRelease" },
    "schema": { "const": "urn:ixo:domain-md:x-oracle-capsule:manifest:0.1.0" },
    "metadata": {
      "type": "object",
      "required": ["name", "release", "created", "issuer", "operator", "release_digest", "supersedes"],
      "properties": {
        "name": { "$ref": "#/$defs/name" },
        "release": { "$ref": "#/$defs/semver" },
        "created": { "type": "string", "format": "date-time" },
        "issuer": { "$ref": "#/$defs/did" },
        "operator": { "$ref": "#/$defs/did" },
        "release_digest": { "$ref": "#/$defs/sha256" },
        "supersedes": {
          "anyOf": [{ "$ref": "#/$defs/cid" }, { "type": "null" }]
        }
      },
      "additionalProperties": false
    },
    "provenance": {
      "type": "object",
      "required": ["repository", "commit", "builder", "reviewed_contract"],
      "properties": {
        "repository": { "$ref": "#/$defs/httpsUri" },
        "commit": { "type": "string", "pattern": "^[0-9a-f]{40}$" },
        "builder": { "$ref": "#/$defs/did" },
        "build_attestation": {
          "anyOf": [{ "$ref": "#/$defs/artifact" }, { "type": "null" }]
        },
        "reviewed_contract": {
          "type": "object",
          "required": ["repository", "commit", "architecture_sha256", "threat_model_sha256"],
          "properties": {
            "repository": { "$ref": "#/$defs/httpsUri" },
            "commit": { "type": "string", "pattern": "^[0-9a-f]{40}$" },
            "architecture_sha256": { "$ref": "#/$defs/sha256" },
            "threat_model_sha256": { "$ref": "#/$defs/sha256" }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "compatibility": {
      "type": "object",
      "required": ["contract_major", "minimum_kernel", "required_features", "hosts"],
      "properties": {
        "contract_major": { "const": "v0alpha1" },
        "minimum_kernel": { "$ref": "#/$defs/semver" },
        "required_features": { "$ref": "#/$defs/uniqueNames" },
        "hosts": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "enum": ["codex", "claude", "pi", "cli", "mcp", "other"] }
        }
      },
      "additionalProperties": false
    },
    "domains": {
      "type": "object",
      "required": ["oracle", "subjects"],
      "properties": {
        "oracle": { "$ref": "#/$defs/domainReference" },
        "subjects": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/domainReference" }
        }
      },
      "additionalProperties": false
    },
    "components": {
      "type": "array",
      "minItems": 1,
      "maxItems": 512,
      "items": { "$ref": "#/$defs/component" },
      "contains": {
        "type": "object",
        "properties": { "kind": { "const": "master_skill" } },
        "required": ["kind"]
      },
      "minContains": 1,
      "maxContains": 1
    },
    "tools": {
      "type": "array",
      "maxItems": 256,
      "items": { "$ref": "#/$defs/tool" }
    },
    "requestedCapabilities": {
      "type": "array",
      "maxItems": 256,
      "items": {
        "type": "object",
        "required": ["id", "action", "object", "tool"],
        "properties": {
          "id": { "$ref": "#/$defs/name" },
          "action": { "$ref": "#/$defs/name" },
          "object": { "$ref": "#/$defs/name" },
          "tool": { "$ref": "#/$defs/name" }
        },
        "additionalProperties": false
      }
    },
    "effectCeiling": {
      "type": "object",
      "required": ["mode", "allowed", "forbidden", "human_review_required_for"],
      "properties": {
        "mode": { "enum": ["read_only", "propose_only", "bounded_evaluate", "bounded_execute"] },
        "allowed": { "$ref": "#/$defs/uniqueNames" },
        "forbidden": { "$ref": "#/$defs/uniqueNames" },
        "human_review_required_for": { "$ref": "#/$defs/uniqueNames" }
      },
      "additionalProperties": false
    },
    "external_checks_required": {
      "type": "array",
      "minItems": 8,
      "maxItems": 8,
      "uniqueItems": true,
      "items": {
        "enum": [
          "oracle-identity-current",
          "subject-domain-current",
          "capability-current-and-unrevoked",
          "trusted-time-available",
          "private-resource-access-authorized",
          "human-review-authorized",
          "runtime-distribution-trusted",
          "receipt-signer-current-and-unrevoked"
        ]
      },
      "allOf": [
        { "contains": { "const": "oracle-identity-current" } },
        { "contains": { "const": "capability-current-and-unrevoked" } },
        { "contains": { "const": "trusted-time-available" } },
        { "contains": { "const": "runtime-distribution-trusted" } },
        { "contains": { "const": "receipt-signer-current-and-unrevoked" } }
      ]
    }
  },
  "additionalProperties": false,
  "$defs": {
    "name": { "type": "string", "minLength": 1, "maxLength": 200, "pattern": "^[A-Za-z0-9][A-Za-z0-9._:/-]*$" },
    "semver": { "type": "string", "pattern": "^(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)(?:-[0-9A-Za-z-]+(?:\\.[0-9A-Za-z-]+)*)?(?:\\+[0-9A-Za-z-]+(?:\\.[0-9A-Za-z-]+)*)?$" },
    "did": { "type": "string", "pattern": "^did:ixo:[A-Za-z0-9._:%-]+$" },
    "sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "cid": { "type": "string", "pattern": "^b[a-z2-7]{10,}$" },
    "httpsUri": { "type": "string", "pattern": "^https://[^/?#]+/[^?#]*$" },
    "immutableUri": { "type": "string", "pattern": "^(ipfs://b[a-z2-7]{10,}(?:/[^?#]*)?|https://[^/?#]+/[^?#]*|file:[^?#]+)$" },
    "relativePath": { "type": "string", "minLength": 1, "maxLength": 1024, "pattern": "^(?!/)(?!.*(?:^|/)\\.\\.(?:/|$))(?!.*\\\\)(?!.*//)[A-Za-z0-9._-]+(?:/[A-Za-z0-9._-]+)*$" },
    "uniqueNames": { "type": "array", "uniqueItems": true, "items": { "$ref": "#/$defs/name" } },
    "artifact": {
      "type": "object",
      "required": ["uri", "cid", "sha256", "media_type", "bytes"],
      "properties": {
        "uri": { "$ref": "#/$defs/immutableUri" },
        "cid": { "$ref": "#/$defs/cid" },
        "sha256": { "$ref": "#/$defs/sha256" },
        "media_type": { "type": "string", "pattern": "^[A-Za-z0-9!#$&^_.+-]+/[A-Za-z0-9!#$&^_.+-]+$" },
        "bytes": { "type": "integer", "minimum": 0, "maximum": 67108864 },
        "source_lock": { "$ref": "#/$defs/sourceLockReference" }
      },
      "additionalProperties": false
    },
    "sourceLockReference": {
      "type": "object",
      "required": ["uri", "cid", "sha256", "media_type", "bytes"],
      "properties": {
        "uri": { "$ref": "#/$defs/immutableUri" },
        "cid": { "$ref": "#/$defs/cid" },
        "sha256": { "$ref": "#/$defs/sha256" },
        "media_type": { "const": "application/vnd.ixo.oracle-capsule.source-lock+json" },
        "bytes": { "type": "integer", "minimum": 1, "maximum": 1048576 }
      },
      "additionalProperties": false
    },
    "domainReference": {
      "type": "object",
      "required": ["id", "uri", "cid", "sha256", "version"],
      "properties": {
        "id": { "$ref": "#/$defs/did" },
        "uri": { "$ref": "#/$defs/immutableUri" },
        "cid": { "$ref": "#/$defs/cid" },
        "sha256": { "$ref": "#/$defs/sha256" },
        "version": { "type": "string", "minLength": 1, "maxLength": 100 }
      },
      "additionalProperties": false
    },
    "component": {
      "type": "object",
      "required": ["id", "kind", "required", "artifact", "version", "owner", "update_authority", "compatibility", "dependencies", "disclosure", "loading_policy", "runtime_writable"],
      "properties": {
        "id": { "$ref": "#/$defs/name" },
        "kind": { "enum": ["master_skill", "specialist_skill", "runtime_bundle", "script_bundle", "policy", "rubric", "output_schema", "reference_memory", "evaluation_suite", "host_adapter"] },
        "required": { "type": "boolean" },
        "artifact": { "$ref": "#/$defs/artifact" },
        "version": { "$ref": "#/$defs/semver" },
        "owner": { "$ref": "#/$defs/did" },
        "update_authority": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "$ref": "#/$defs/did" } },
        "compatibility": { "$ref": "#/$defs/uniqueNames" },
        "dependencies": { "$ref": "#/$defs/uniqueNames" },
        "disclosure": { "enum": ["public", "authorized_projection", "never_model_visible"] },
        "loading_policy": { "enum": ["bootstrap", "on_demand", "runtime_only"] },
        "runtime_writable": { "const": false },
        "entrypoint": { "$ref": "#/$defs/relativePath" }
      },
      "additionalProperties": false,
      "allOf": [
        {
          "if": { "properties": { "kind": { "const": "master_skill" } }, "required": ["kind"] },
          "then": {
            "required": ["entrypoint"],
            "properties": {
              "required": { "const": true },
              "loading_policy": { "const": "bootstrap" },
              "artifact": { "type": "object", "required": ["source_lock"] }
            }
          }
        }
      ]
    },
    "tool": {
      "type": "object",
      "required": ["id", "did", "version", "manifest", "input_schema", "output_schema", "risk_tier", "side_effect", "capability", "sandbox", "egress", "receipt_schema"],
      "properties": {
        "id": { "$ref": "#/$defs/name" },
        "did": { "$ref": "#/$defs/did" },
        "version": { "$ref": "#/$defs/semver" },
        "manifest": { "$ref": "#/$defs/artifact" },
        "input_schema": { "$ref": "#/$defs/artifact" },
        "output_schema": { "$ref": "#/$defs/artifact" },
        "risk_tier": { "enum": ["low", "moderate", "high", "critical"] },
        "side_effect": { "enum": ["none", "reversible", "irreversible", "value_movement", "canonical_state"] },
        "capability": { "type": "object", "required": ["required", "actions"], "properties": { "required": { "const": true }, "actions": { "$ref": "#/$defs/uniqueNames" } }, "additionalProperties": false },
        "sandbox": { "type": "object", "required": ["network", "filesystem", "secrets"], "properties": { "network": { "enum": ["none", "allowlist"] }, "filesystem": { "enum": ["none", "read_only_projection"] }, "secrets": { "const": "adapter_only" } }, "additionalProperties": false },
        "egress": { "type": "object", "required": ["destinations", "fields"], "properties": { "destinations": { "$ref": "#/$defs/uniqueNames" }, "fields": { "$ref": "#/$defs/uniqueNames" } }, "additionalProperties": false },
        "receipt_schema": { "$ref": "#/$defs/artifact" }
      },
      "additionalProperties": false
    }
  }
}
